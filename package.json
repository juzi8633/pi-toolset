{
  "name": "pi-lsp",
  "version": "0.0.1",
  "description": "pi lsp support",
  "author": {
    "name": "balaenis",
    "email": "pzyyll@gmail.com"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "lsp",
    "language-server"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/balaenis/pi-lsp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/version.ts"
  ],
  "dependencies": {
    "vscode-jsonrpc": "^8.2.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "8.47.0",
    "@typescript-eslint/parser": "8.47.0",
    "bun-types": "latest",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typebox": "*",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
