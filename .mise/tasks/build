#!/usr/bin/env bash
#MISE description="Build the project"
#MISE depends=["setup"]
#MISE sources=["src/**/*"]
#MISE outputs=["dist/index.js"]

# Externalize the Pi SDK peer packages so the host provides them at runtime.
# Bundling them would load a second SDK instance, breaking type/identity checks.
bun build ./src/index.ts --outdir dist --target bun \
  --external @earendil-works/pi-ai \
  --external @earendil-works/pi-coding-agent \
  --external typebox

# If you need to exclude additional packages from your bundle, add more --external flags above.
