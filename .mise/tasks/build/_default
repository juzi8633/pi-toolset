#!/usr/bin/env bash
#MISE description="Build a package"
#MISE depends=["setup"]
#USAGE flag "-p --package <path>" "Package dir, e.g. packages/pi-lsp" default=""

set -e
PKG="${usage_package}"
[ -d "$PKG" ] || { echo "no such package: ${usage_package:-<missing>}" >&2; exit 1; }
cd "$PKG"

# Externalize peer packages (host provides them at runtime) plus this package's
# declared extra externals. Bundling peer deps would load a second SDK instance
# and break type/identity checks against the host's copy.
EXTERNALS=$(jq -r '(.peerDependencies // {}) | keys[]' package.json)
EXTRA=$(jq -r '(.pi.external // [])[]' package.json 2>/dev/null || true)

args=()
for e in $EXTERNALS $EXTRA; do args+=(--external "$e"); done

bun build ./src/index.ts --outdir dist --target node "${args[@]}"

# Optional child-only extension entry (pi-agents artifact reader).
ARTIFACT_READER="./src/run/artifact-reader-extension.ts"
if [ ! -f "$ARTIFACT_READER" ]; then
  ARTIFACT_READER="./src/artifact-reader-extension.ts"
fi
if [ -f "$ARTIFACT_READER" ]; then
  bun build "$ARTIFACT_READER" --outdir dist --target node "${args[@]}"
fi

if jq -e '.scripts.postbuild' package.json >/dev/null 2>&1; then
  bun run postbuild
fi
