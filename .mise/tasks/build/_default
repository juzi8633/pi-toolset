#!/usr/bin/env bash
#MISE description="Build a package"
#MISE depends=["setup"]
#USAGE flag "-p --package <path>" "Package dir, e.g. packages/pi-lsp" default=""

set -euo pipefail
PKG="${usage_package}"
[ -d "$PKG" ] || { echo "no such package: ${usage_package:-<missing>}" >&2; exit 1; }
cd "$PKG"

# Externalize host peers and explicit pi.external entries only. Package runtime
# dependencies bundle into dist unless listed in pi.external. Host peers must
# stay external so identity checks and virtual-module resolution keep working.
# Strip CR from jq output — Windows jq emits CRLF and breaks --external.
EXTERNALS_FILE="$(mktemp)"
METAFILE=""
cleanup() {
  rm -f "$EXTERNALS_FILE"
  if [ -n "${METAFILE:-}" ]; then
    rm -f "$METAFILE"
  fi
}
trap cleanup EXIT
jq -r '([.peerDependencies // {}] | map(keys) | add) + (.pi.external // []) | unique[]' package.json \
  | tr -d '\r' >"$EXTERNALS_FILE"

external_args=()
while IFS= read -r e || [ -n "${e:-}" ]; do
  [ -n "${e:-}" ] || continue
  external_args+=(--external "$e")
done <"$EXTERNALS_FILE"

if [ "${#external_args[@]}" -eq 0 ]; then
  echo "warning: no externals resolved for $PKG; peer/host packages may be bundled" >&2
fi

SPLITTING="$(jq -r '.pi.build.splitting // false' package.json | tr -d '\r')"
main_args=(./src/index.ts --outdir dist --target node)
if [ "$SPLITTING" = "true" ]; then
  rm -rf dist/chunks
  METAFILE="$(mktemp)"
  main_args+=(--splitting --chunk-naming "chunks/[name]-[hash].[ext]" --metafile="$METAFILE")
fi

bun build "${main_args[@]}" "${external_args[@]}"

# Optional child-only extension entry (pi-agents artifact reader).
ARTIFACT_READER="./src/run/artifact-reader-extension.ts"
if [ ! -f "$ARTIFACT_READER" ]; then
  ARTIFACT_READER="./src/artifact-reader-extension.ts"
fi
if [ -f "$ARTIFACT_READER" ]; then
  bun build "$ARTIFACT_READER" --outdir dist --target node "${external_args[@]}"
fi

run_postbuild() {
  if [ -n "${METAFILE:-}" ]; then
    export PI_BUILD_METAFILE="$METAFILE"
  else
    unset PI_BUILD_METAFILE || true
  fi
  if jq -e '.scripts.postbuild' package.json >/dev/null 2>&1; then
    bun run postbuild
  elif [ -f ./scripts/postbuild.ts ]; then
    bun run ./scripts/postbuild.ts
  fi
}

run_postbuild
