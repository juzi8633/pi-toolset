{
  "name": "@balaenis/pi-lsp",
  "version": "0.1.0",
  "description": "pi lsp support",
  "license": "Apache-2.0",
  "author": {
    "name": "balaenis",
    "email": "pzyyll@gmail.com"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "lsp",
    "language-server"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "external": [
      "vscode-jsonrpc"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/balaenis/pi-toolset.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "dependencies": {
    "vscode-jsonrpc": "^9.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "scripts": {
    "gen:schema": "bun run scripts/gen-schema.ts",
    "postbuild": "bun run gen:schema"
  },
  "devDependencies": {
    "vscode-languageserver-protocol": "^3.18.0",
    "vscode-languageserver-types": "^3.18.0"
  }
}
