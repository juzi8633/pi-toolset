{
  "name": "@balaenis/pi-agents",
  "version": "0.2.0",
  "description": "Delegate tasks to specialized subagents with isolated context windows.",
  "license": "Apache-2.0",
  "author": {
    "name": "balaenis",
    "email": "pzyyll@gmail.com"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "subagent",
    "agent"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./artifact-reader-extension": "./dist/artifact-reader-extension.js"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "prompts": [
      "./prompts"
    ],
    "agents": [
      "./agents"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/balaenis/pi-toolset.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "agents",
    "prompts",
    "THIRD_PARTY_NOTICES.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@balaenis/pi-log": "0.0.0",
    "@earendil-works/pi-agent-core": "0.81.0",
    "jiti": "2.7.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "effect": "^3.22.0"
  }
}
